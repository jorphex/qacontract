# Safe template only. Do not put real secrets in committed files.

PROMPTCLAIM_ACCOUNT=your-ape-account-alias
# Optional. Omit to use the script default for the selected network.
# PROMPTCLAIM_TOKEN=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
PROMPTCLAIM_REFUND_TO=0xYourRefundAddress
PROMPTCLAIM_AMOUNT=1000000
PROMPTCLAIM_DEADLINE=1893456000
PROMPTCLAIM_ANSWER_HASH=0xYourAnswerHash
PROMPTCLAIM_ADDRESS=0xYourDeployedPromptClaim

PUZZLEGIVEAWAY_ACCOUNT=your-ape-account-alias
# Optional. Omit to use the script default for the selected Base network.
# If set, this overrides the selected-network default.
# Base mainnet default: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia default: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# PUZZLEGIVEAWAY_TOKEN=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
PUZZLEGIVEAWAY_REFUND_TO=0xYourRefundAddress
PUZZLEGIVEAWAY_PROMPT=What is the answer?
PUZZLEGIVEAWAY_MAX_AMOUNT=1000000
PUZZLEGIVEAWAY_FLOOR_AMOUNT=250000
PUZZLEGIVEAWAY_DEADLINE=1893456000
PUZZLEGIVEAWAY_CLIFF_SECONDS=60
PUZZLEGIVEAWAY_ANSWER_HASH=0xYourAnswerHash
# Set after deploy/fund; used by start_puzzle_giveaway.
PUZZLEGIVEAWAY_ADDRESS=0xYourDeployedPuzzleGiveaway

PUZZLEGIVEAWAY_V3_ACCOUNT=your-ape-account-alias
# Optional. Omit to use the script default for the selected Base network.
# If set, this overrides the selected-network default.
# Base mainnet default: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia default: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# PUZZLEGIVEAWAY_V3_TOKEN=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
PUZZLEGIVEAWAY_V3_REFUND_TO=0xYourRefundAddress
PUZZLEGIVEAWAY_V3_PROMPT=What is the answer?
PUZZLEGIVEAWAY_V3_MAX_AMOUNT=1000000
PUZZLEGIVEAWAY_V3_FLOOR_AMOUNT=10000
PUZZLEGIVEAWAY_V3_DEADLINE=1893456000
PUZZLEGIVEAWAY_V3_CLIFF_SECONDS=60
# 2 = quadratic, 3 = cubic.
PUZZLEGIVEAWAY_V3_CURVE_EXPONENT=2
PUZZLEGIVEAWAY_V3_ANSWER_HASH=0xYourAnswerHash
# Set after deploy/fund; used by start_puzzle_giveaway_v3.
PUZZLEGIVEAWAY_V3_ADDRESS=0xYourDeployedPuzzleGiveawayV3
