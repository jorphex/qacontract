# Safe template only. Do not put real secrets in committed files.

PROMPTCLAIM_ACCOUNT=your-ape-account-alias
# Optional. Omit to use the script default for the selected network.
# PROMPTCLAIM_TOKEN=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
PROMPTCLAIM_REFUND_TO=0xYourRefundAddress
PROMPTCLAIM_AMOUNT=1000000
PROMPTCLAIM_DEADLINE=1893456000
PROMPTCLAIM_ANSWER_HASH=0xYourAnswerHash
PROMPTCLAIM_ADDRESS=0xYourDeployedPromptClaim

PUZZLEGIVEAWAY_ACCOUNT=your-ape-account-alias
# Optional. Omit to use the script default for the selected network.
# PUZZLEGIVEAWAY_TOKEN=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
PUZZLEGIVEAWAY_REFUND_TO=0xYourRefundAddress
PUZZLEGIVEAWAY_MAX_AMOUNT=1000000
PUZZLEGIVEAWAY_FLOOR_AMOUNT=250000
PUZZLEGIVEAWAY_DEADLINE=1893456000
PUZZLEGIVEAWAY_CLIFF_SECONDS=60
PUZZLEGIVEAWAY_ANSWER_HASH=0xYourAnswerHash
# Set after deploy/fund; used by start_puzzle_giveaway.
PUZZLEGIVEAWAY_ADDRESS=0xYourDeployedPuzzleGiveaway
