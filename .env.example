# Safe template only. Do not put real secrets in committed files.

KINGOFTHEHILL_ACCOUNT=your-ape-account-alias
# Optional. Omit to use the script default for the selected Base network.
# If set, this overrides the selected-network default.
# Base mainnet default: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia default: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# KINGOFTHEHILL_TOKEN=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
KINGOFTHEHILL_REFUND_TO=0xYourRefundAddress
KINGOFTHEHILL_PROMPT=What is the answer?
KINGOFTHEHILL_MAX_AMOUNT=1000000
KINGOFTHEHILL_FLOOR_AMOUNT=10000
KINGOFTHEHILL_DEADLINE=1893456000
KINGOFTHEHILL_MAX_SHOTS=5
# 1 = linear, 2 = quadratic, 3 = cubic.
KINGOFTHEHILL_CURVE_EXPONENT=2
KINGOFTHEHILL_ANSWER_HASH=0xYourAnswerHash
# Set after deploy/fund; used by start_king_of_the_hill.
KINGOFTHEHILL_ADDRESS=0xYourDeployedKingOfTheHillGiveaway
